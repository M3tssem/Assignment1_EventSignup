@model List<Assignment1_EventSignup.Models.Event>

<h1>Event Manager</h1>

<table class="table">
    <tr>
        <th>Title</th>
        <th>Date</th>
        <th>Location</th>
        <th></th>
    </tr>

    @foreach (var e in Model)
    {
            <tr>
                <td>@e.Title</td>
                <td>@e.Date.ToShortDateString()</td>
                <td>@e.Location</td>
                <td>
                    <a class="btn btn-primary">
                        Manage Attendees
                    </a>
                </td>
            </tr>
    }
</table>